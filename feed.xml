---
layout: null
---
<?xml version="1.0" encoding="utf-8" ?>
<!-- https://github.com/jekyll/jekyll-feed/blob/master/lib/jekyll-feed/feed.xml -->
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="en-US">
  <generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">
    Jekyll
  </generator>
  <link
    href="{{ page.url | absolute_url }}"
    rel="self"
    type="application/atom+xml"
  />
  <link
    href="{{ '/' | absolute_url }}"
    rel="alternate"
    type="text/html"
    hreflang="en-US"
  />
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ page.url | absolute_url | xml_escape }}</id>

  <title>Longer Tweets</title>
  <subtitle>Yet another blog by SheepTester</subtitle>

  <author>
    <name>SheepTester</name>
    <email>seanthesheep22+longtweet@outlook.com</email>
    <uri>https://sheeptester.github.io/</uri>
  </author>

  {% assign posts = site.posts %}
  {% assign posts = posts | where_exp: "post", "post.unlisted != true" %}
  {% unless site.show_drafts %}
    {% assign posts = posts | where_exp: "post", "post.draft != true" %}
  {% endunless %}
  {% assign posts = posts | sort: "date" | reverse %}

  {% for post in posts limit: 10 %}
  <entry xml:lang="en-US">
    <id>{{ post.id | absolute_url | xml_escape }}</id>

    {% assign
    post_title = post.title | strip_html | smartify | normalize_whitespace | xml_escape %}
    <title type="html">{{ post_title }}</title>
    <summary type="html">
      {{ post.description | strip_html | smartify | normalize_whitespace | xml_escape }}
    </summary>
    <link
      href="{{ post.url | absolute_url }}"
      rel="alternate"
      type="text/html"
      title="{{ post_title }}"
    />

    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>
      {{ post.last_modified_at | default: post.date | date_to_xmlschema }}
    </updated>

    <author>
      <name>SheepTester</name>
      <email>seanthesheep22+longtweet@outlook.com</email>
      <uri>https://sheeptester.github.io/</uri>
    </author>

    {% for tag in post.tags %}
    <category term="{{ tag | xml_escape }}" />
    {% endfor %}
  </entry>
  {% endfor %}
</feed>
